    "@docdrift/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^21.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
