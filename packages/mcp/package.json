{
  "name": "@docdrift/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "DocDrift MCP server — analyze PRs for documentation drift and write Confluence pages",
  "bin": {
    "docdrift-mcp": "./dist/index.js"
  },
