# DocDrift — local development environment
# Copy to .env and fill in your values. Never commit .env.

# ── LLM Providers ──────────────────────────────────────────────────────────────
# HuggingFace API token (primary LLM when set)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Anthropic API key (used as fallback when HF_TOKEN is set, or primary when HF_TOKEN is not)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── GitHub ──────────────────────────────────────────────────────────────────────
# Fine-grained PAT with: pull_requests: write, contents: read
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE

# ── Confluence (optional) ───────────────────────────────────────────────────────
# CONFLUENCE_URL=https://yourorg.atlassian.net/wiki
# CONFLUENCE_EMAIL=you@yourorg.com
# CONFLUENCE_API_TOKEN=YOUR_ATLASSIAN_TOKEN_HERE
# CONFLUENCE_SPACE_KEY=TECH
